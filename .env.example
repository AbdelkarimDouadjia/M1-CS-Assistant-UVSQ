# ================================================================
# M1 Informatique Chatbot - Example environment file
# ================================================================
# Usage:
#   1. Copy this file to .env
#      PowerShell: copy .env.example .env
#   2. Put your own API keys in .env only.
#   3. Never commit .env.

# ================================================================
# 1) Main LLM routing
# ================================================================
# auto = Gemini first, optional OpenAI-compatible providers second,
#        UVSQ/vLLM server last as backup.
# gemini = force Gemini only
# vllm = force UVSQ/vLLM server only
# fallback = force FALLBACK_MODEL on the vLLM-compatible server
ACTIVE_BACKEND=auto

# Gemini is the default release backend.
GEMINI_API_KEY=PASTE_YOUR_GEMINI_API_KEY_HERE
GEMINI_MODEL=gemini-2.5-flash

# Used for uploaded image understanding before sending text to the main LLM.
VISION_MODEL=gemini-2.5-flash

# Generation parameters.
GENERATION_TEMPERATURE=0.1
GENERATION_MAX_TOKENS=800
REQUEST_TIMEOUT=5

# ================================================================
# 2) UVSQ / vLLM server backup
# ================================================================
# These URLs work only when the SSH tunnel is open:
# ssh -L 8000:localhost:8000 -L 8001:localhost:8001 YOUR_SERVER_USER@charizard.prism.uvsq.fr
VLLM_API_BASE=http://localhost:8000/v1
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=unused
VLLM_MODEL=Qwen/Qwen3-30B-A3B
ANSWER_MODEL=Qwen/Qwen3-30B-A3B
FALLBACK_MODEL=
VLLM_TIMEOUT=10
VLLM_PROBE_TIMEOUT=1

# ================================================================
# 3) RAG retrieval
# ================================================================
EMBEDDING_MODEL=BAAI/bge-m3
RETRIEVAL_TOP_K=12
FINAL_CONTEXT_K=5
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# Optional smart chunking. Disabled by default because it calls Gemini during
# ingestion. Enable it when you want document-specific YAML chunking configs.
SMART_CHUNKING_ENABLED=false
SMART_CHUNKING_MODEL=gemini-2.5-flash

# ================================================================
# 4) Re-ranker
# ================================================================
# First tries the server reranker if the tunnel is open.
RERANKING_ENABLED=true
RERANKER_API_BASE=http://localhost:8001
RERANKER_MODEL=Qwen/Qwen3-Reranker-4B

# If the server reranker is unavailable, this local fallback reproduces the
# older project behavior with sentence-transformers CrossEncoder.
LOCAL_RERANKER_ENABLED=true
LOCAL_RERANKER_MODEL=BAAI/bge-reranker-base

# ================================================================
# 5) Re-asker / query expansion
# ================================================================
# Safe replacement for the older rerasker: no hardcoded provider key.
# It uses the configured LLM chain, so Gemini works here too.
QUERY_EXPANSION_ENABLED=false
QUERY_EXPANSION_MAX_VARIANTS=3

# Backward-compatible aliases from the older project naming.
RERASKER_ENABLED=false
RERASKER_MAX_VARIANTS=3

# ================================================================
# 6) Optional OpenAI-compatible providers
# ================================================================
# These providers are tried after Gemini and before the UVSQ/vLLM backup.
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=deepseek-chat
OPENAI_COMPAT_MODELS=
OPENAI_COMPAT_MULTI=false
OPENAI_COMPAT_TIMEOUT=90

# Second optional OpenAI-compatible gateway.
OPENAI_COMPAT2_BASE_URL=
OPENAI_COMPAT2_API_KEY=
OPENAI_COMPAT2_MODELS=
OPENAI_COMPAT2_TIMEOUT=
