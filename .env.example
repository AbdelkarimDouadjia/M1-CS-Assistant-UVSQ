VLLM_API_BASE=http://localhost:8000/v1
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=unused
VLLM_MODEL=Qwen/Qwen3-30B-A3B
ANSWER_MODEL=Qwen/Qwen3-30B-A3B
FALLBACK_MODEL=

RERANKER_API_BASE=http://localhost:8001
RERANKER_MODEL=Qwen/Qwen3-Reranker-4B
RERANKING_ENABLED=true

EMBEDDING_MODEL=BAAI/bge-m3
CHUNK_SIZE=1200
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=12
FINAL_CONTEXT_K=5

GENERATION_TEMPERATURE=0.1
GENERATION_MAX_TOKENS=800
REQUEST_TIMEOUT=5
VLLM_TIMEOUT=10

GEMINI_API_KEY=

# --- Passerelles OpenAI-compatible (secours après vLLM, avant GEMINI / FALLBACK_MODEL vLLM) ---
# Ne commitez jamais de clé : .env local uniquement.
# OPENAI_COMPAT_BASE_URL=https://aiapiv2.pekpik.com/v1
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
# Un seul modèle (prioritaire si OPENAI_COMPAT_MODELS est vide) :
OPENAI_COMPAT_MODEL=deepseek-chat
# Plusieurs modèles sur la MÊME URL (essayés dans l’ordre si le précédent échoue) :
# OPENAI_COMPAT_MODELS=deepseek-chat,gemini-2.5-flash,gemini-2.5-pro,claude-sonnet-4-6,flagship-chat,mistral-medium-latest,deepseek-reasoner
# Ou chaîne par défaut du code (voir llm_backends.OPENAI_COMPAT_DEFAULT_MODEL_CHAIN) :
# OPENAI_COMPAT_MULTI=true
OPENAI_COMPAT_TIMEOUT=90

# Deuxième passerelle (URL + clé différentes). OPENAI_COMPAT2_MODELS vide = mêmes noms que le 1er bloc.
OPENAI_COMPAT2_BASE_URL=
OPENAI_COMPAT2_API_KEY=
OPENAI_COMPAT2_MODELS=
OPENAI_COMPAT2_TIMEOUT=
